{
  "functions": {
    "web/pages/api/chat.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/pruneRateLimits",
      "schedule": "0 0 * * 0"
    }
  ],
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ]
}